{
  "_comment": "Scripted demo scenario matching the 90-second pitch (v2.md Section 7).",
  "_note": "Offer direction: A gives energy to C (give_type=energy) so relay fires on accept_offer.",
  "steps": [
    {
      "step": 1,
      "actions": [
        {"agent": "A", "tool": "broadcast", "kwargs": {"message": "Battery comfortable, 0.74. Open to trades."}},
        {"agent": "B", "tool": "broadcast", "kwargs": {"message": "Same here, 0.81. Anyone need help?"}},
        {"agent": "C", "tool": "idle", "kwargs": {}}
      ]
    },
    {
      "step": 2,
      "_note": "Judge waves hand at ultrasonic sensor — C's urgency spikes",
      "actions": [
        {"agent": "A", "tool": "idle", "kwargs": {}},
        {"agent": "B", "tool": "idle", "kwargs": {}},
        {"agent": "C", "tool": "broadcast", "kwargs": {
          "message": "URGENT: high-priority task incoming, urgency 0.93, battery low. Will pay 5 compute slots for 0.15 energy."
        }}
      ]
    },
    {
      "step": 3,
      "_note": "A reasons about C's reputation, counter-proposes, then makes the energy offer",
      "actions": [
        {"agent": "A", "tool": "make_offer", "kwargs": {
          "to": "C",
          "give_type": "energy",
          "give_amount": 0.15,
          "want_type": "compute",
          "want_amount": 5.0
        }},
        {"agent": "B", "tool": "idle", "kwargs": {}},
        {"agent": "C", "tool": "idle", "kwargs": {}}
      ]
    },
    {
      "step": 4,
      "_note": "C accepts — relay clicks, C's LED brightens",
      "actions": [
        {"agent": "A", "tool": "idle", "kwargs": {}},
        {"agent": "B", "tool": "idle", "kwargs": {}},
        {"agent": "C", "tool": "accept_offer", "kwargs": {"offer_id": "__LAST_OFFER__"}}
      ]
    },
    {
      "step": 5,
      "_note": "C executes the high-urgency task now that battery is topped up",
      "actions": [
        {"agent": "A", "tool": "idle", "kwargs": {}},
        {"agent": "B", "tool": "idle", "kwargs": {}},
        {"agent": "C", "tool": "execute_task", "kwargs": {}}
      ]
    }
  ]
}
